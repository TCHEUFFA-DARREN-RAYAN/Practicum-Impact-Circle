PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_NAME=impactcircle
DB_USER=root
DB_PASS=your_mysql_password_here
DB_LOGGING=false

JWT_SECRET=replace_this_with_a_256bit_random_string
JWT_EXPIRES_IN=7d

# Local mail: set EMAIL_USE_ETHEREAL=true — Nodemailer uses Ethereal; the server logs a preview URL.
# Production / Mailgun later: set EMAIL_USE_ETHEREAL=false and configure SMTP below.
EMAIL_USE_ETHEREAL=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="ImpactCircle" <noreply@impactcircle.local>

# TLS: set to false only on trusted dev machines behind SSL-inspecting proxies (weakens MITM protection).
# EMAIL_TLS_REJECT_UNAUTHORIZED=false

NODE_ENV=development
ADMIN_EMAIL=admin@impactcircle.ca
ADMIN_PASS=Admin@123456
# Base URL for links in emails (password reset, etc.)
CLIENT_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000
