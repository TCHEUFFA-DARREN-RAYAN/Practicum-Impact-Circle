# Test environment configuration
# Copy to .env.test and fill in values for running tests

NODE_ENV=test
PORT=5001

# Use a separate test database to avoid corrupting development data
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=impactcircle_test

JWT_SECRET=test-secret-do-not-use-in-production

# Email — use a local mail trap in test environments
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=test@impactcircle.local
EMAIL_TLS_REJECT_UNAUTHORIZED=false

# Disable auto-approval cron in tests
DISABLE_AUTO_APPROVAL=true
